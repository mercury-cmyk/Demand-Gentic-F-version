NODE_ENV=development
STRICT_ENV_ISOLATION=true

# Required: dedicated development database
DATABASE_URL_DEV=postgresql://user:password@host:5432/dev_db

# Recommended: dedicated development Redis
REDIS_URL_DEV=redis://localhost:6379

# Optional safety comparisons
DATABASE_URL_PROD=postgresql://user:password@host:5432/prod_db
REDIS_URL_PROD=redis://prod-redis-host:6379

# Prevent dev from using shared/prod resources unless explicitly allowed
ALLOW_DEV_PROD_DB=false
ALLOW_DEV_PROD_REDIS=false
ALLOW_DEV_PROD_ENDPOINTS=false
ALLOW_SHARED_REDIS_IN_DEV=false

# Host markers blocked in development when ALLOW_DEV_PROD_ENDPOINTS=false
PRODUCTION_HOST_DENYLIST=demandgentic.ai,.run.app
