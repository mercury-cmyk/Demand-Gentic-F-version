{"id":"ex011","text":"You have reached the voicemail of John Smith. I'm not available to take your call. Please leave a message after the tone.","labels":{"entry":"VOICEMAIL_PERSONAL"},"action":{"type":"STATE_ENTER_VOICEMAIL_MODE","policy":"NO_VM_DROP","next":"END_CALL_POLITE"}}
