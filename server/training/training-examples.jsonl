{"id":"ex013","text":"The mailbox is full and cannot accept messages at this time.","labels":{"entry":"VOICEMAIL_GENERIC"},"action":{"type":"STATE_ENTER_VOICEMAIL_MODE","next":"END_CALL_POLITE","note":"mark mailbox full"}}
