{"id":"ex001","text":"Welcome to Acme Corporation. Please listen carefully as our options have changed. For sales press 1, for support press 2, for dial-by-name directory press 3, to reach the operator press 0.","labels":{"entry":"IVR_MENU"},"action":{"type":"STATE_ENTER_IVR_MODE","next":"SEND_DTMF","dtmf":"3"}}
{"id":"ex002","text":"If you know your party's extension, you may dial it at any time. To use the dial-by-name directory, press 9.","labels":{"entry":"IVR_MENU"},"action":{"type":"SEND_DTMF","dtmf":"9"}}
{"id":"ex003","text":"Please say the name of the person you are trying to reach.","labels":{"entry":"IVR_MENU"},"action":{"type":"STATE_ENTER_IVR_MODE","next":"PROVIDE_NAME_FOR_DIRECTORY","value":"{{contact_full_name}}"}}
{"id":"ex004","text":"Good morning, Globex Corporation, this is Sarah. How may I direct your call?","labels":{"entry":"RECEPTIONIST_SWITCHBOARD"},"action":{"type":"STATE_ENTER_GATEKEEPER_MODE","next":"REQUEST_TRANSFER_TO_CONTACT"}}
