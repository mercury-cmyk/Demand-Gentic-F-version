# SIP Server Environment Configuration Template
# Copy as .env.sip and fill in required values

# ============================================
# PUBLIC DEPLOYMENT SETTINGS
# ============================================

# Public IP address of the SIP server (REQUIRED)
PUBLIC_IP=203.0.113.42

# Private IP address of the SIP server
PRIVATE_IP=10.0.1.10

# Deployment environment
NODE_ENV=production

# ============================================
# DRACHTIO SIP SERVER CONFIGURATION
# ============================================

# Drachtio daemon hostname/IP
DRACHTIO_HOST=drachtio

# Drachtio command port
DRACHTIO_PORT=9022

# SIP listening port
SIP_LISTEN_PORT=5060

# SIP listening host (0.0.0.0 for all interfaces)
SIP_LISTEN_HOST=0.0.0.0

# Enable auto-initialization on startup
AUTO_INIT_SIP=true

# ============================================
# STUN/TURN CONFIGURATION
# ============================================

# STUN servers (comma-separated)
STUN_SERVERS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302,stun:stun.stunprotocol.org:3478

# TURN servers (JSON array)
# Format: [{"urls":["turn:host:port"],"username":"user","credential":"pass"}]
TURN_SERVERS=[{"urls":["turn:coturn:3478"],"username":"turnuser","credential":"turnpass123"}]

# TURN server credentials (if using authenticated TURN)
TURN_USERNAME=turnuser
TURN_PASSWORD=strongpasswordhere123
TURN_URL=turn:turn.example.com:3478

# ============================================
# RTP MEDIA CONFIGURATION
# ============================================

# RTP port range minimum
RTP_PORT_MIN=10000

# RTP port range maximum
RTP_PORT_MAX=20000

# Monitor ports for availability
MONITOR_PORTS=true

# ============================================
# SIP CALLING CONFIGURATION
# ============================================

# Enable SIP-based calling feature
USE_SIP_CALLING=true

# ============================================
# DATABASE CONFIGURATION
# ============================================

# PostgreSQL connection URL
DATABASE_URL=postgresql://demandgentic:password123@postgres:5432/demandgentic

# Database SSL mode (disable for local, require for production)
DATABASE_SSL=require

# ============================================
# CACHE CONFIGURATION
# ============================================

# Redis connection URL
REDIS_URL=redis://redis:6379

# Disable Redis locally (for testing)
DISABLE_REDIS=false

# ============================================
# AI/LLM CONFIGURATION
# ============================================

# Google Gemini API Key
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Alternative: OpenAI API Key
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# TELNYX CONFIGURATION (Legacy)
# ============================================

# Telnyx WebRTC credentials (for compatibility)
TELNYX_WEBRTC_USERNAME=your-telnyx-username
TELNYX_WEBRTC_PASSWORD=your-telnyx-password
TELNYX_CONNECTION_ID=your-connection-id
TELNYX_WEBRTC_URL=wss://rtc.telnyx.com:14938

# ============================================
# NGROK CONFIGURATION (Development)
# ============================================

# Ngrok auth token (for development tunneling)
NGROK_AUTH_TOKEN=your-ngrok-token-here

# Skip Ngrok tunnel on startup
SKIP_NGROK=false

# ============================================
# LOGGING & MONITORING
# ============================================

# Logging level: error, warn, info, debug
LOG_LEVEL=info

# GCP Project for logging
GCP_PROJECT_ID=your-gcp-project-id

# ============================================
# SECURITY
# ============================================

# JWT secret for authentication
JWT_SECRET=your-secret-key-here-minimum-32-characters

# API rate limiting (requests per minute)
RATE_LIMIT=1000

# ============================================
# CORS CONFIGURATION
# ============================================

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5000,https://app.example.com

# ============================================
# APPLICATION PORTS
# ============================================

# HTTP server port
PORT=5000

# HTTPS server port
HTTPS_PORT=5001

# ============================================
# FEATURE FLAGS
# ============================================

# Enable audio quality fix
ENABLE_AUDIO_FIX=true

# Enable call transcription
ENABLE_TRANSCRIPTION=true

# Enable call recording
ENABLE_RECORDING=true

# ============================================
# DEPLOYMENT SPECIFIC
# ============================================

# Docker compose file
DOCKER_COMPOSE_FILE=docker-compose.sip.yml

# Restart policy for containers
RESTART_POLICY=unless-stopped
