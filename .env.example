# Copy this file to .env and fill in your values

# Database Configuration
DB_PASSWORD=changeme123
DB_PORT=5432

# Redis Configuration
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Application Configuration
APP_PORT=5000
NODE_ENV=production
PUBLIC_WEBHOOK_HOST=demangent.ai
PUBLIC_WEBSOCKET_URL=wss://demangent.ai/openai-realtime-dialer

# Authentication (REQUIRED - Generate strong secrets)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
SESSION_SECRET=your-super-secret-session-key-min-32-chars

# API Keys (REQUIRED for core features)
EMAIL_LIST_VERIFY_API_KEY=your_elv_api_key_here
BRAVE_SEARCH_API_KEY=your_brave_api_key_here

# Telephony Integration (OPTIONAL - Only if using call campaigns)
TELNYX_API_KEY=
TELNYX_SIP_CONNECTION_ID=
SIP_TRUNK_PROVIDER=
SIP_TRUNK_USERNAME=
SIP_TRUNK_PASSWORD=
SIP_TRUNK_DOMAIN=
SIP_TRUNK_CALLER_ID=
SIP_TRUNK_CONNECTION_ID=

# AI Services (OPTIONAL)
OPENAI_API_KEY=
ASSEMBLYAI_API_KEY=

# OpenAI Realtime SIP (OPTIONAL - inbound calls via SIP trunk)
# OPENAI_WEBHOOK_SECRET=

# Mailgun Email Service (REQUIRED for email campaigns)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_PUBLIC_API_KEY=
# OPENAI_SIP_MODEL=gpt-realtime
# OPENAI_SIP_INSTRUCTIONS=You are a helpful voice assistant.
# OPENAI_SIP_GREETING=
# OPENAI_SIP_VOICE=
# OPENAI_SIP_VIRTUAL_AGENT_ID=
# OPENAI_SIP_ALLOWED_TO=+18005551212,+14155550123
# OPENAI_SIP_MAX_OUTPUT_TOKENS=256
# OPENAI_SIP_MONITOR=false
# OPENAI_SIP_SIDEBAND=true
# OPENAI_SIP_SIDEBAND_UPDATE=true
# OPENAI_SIP_TOOL_CHOICE=auto
# OPENAI_SIP_LOG_EVENTS=false
# OPENAI_SIP_SESSION_TIMEOUT_SECONDS=900

# Email Service Providers (OPTIONAL - Choose one or more)
SENDGRID_API_KEY=
AWS_SES_ACCESS_KEY=
AWS_SES_SECRET_KEY=
AWS_SES_REGION=us-east-1
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# PgAdmin (OPTIONAL - for database management)
PGADMIN_PASSWORD=admin123
PGADMIN_PORT=5050

# File Storage (OPTIONAL - defaults to local storage)
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# Inbox OAuth (OPTIONAL - for inbox sync)
MSFT_OAUTH_CLIENT_ID=
MSFT_OAUTH_CLIENT_SECRET=
MSFT_OAUTH_TENANT_ID=common
MSFT_OAUTH_REDIRECT_URI=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_SCOPES=openid email profile https://www.googleapis.com/auth/gmail.readonly https://www.googleapis.com/auth/gmail.send
GOOGLE_OAUTH_REDIRECT_URI=
ENABLE_M365_SYNC=true
ENABLE_GMAIL_SYNC=false
