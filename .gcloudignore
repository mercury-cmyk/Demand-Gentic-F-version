#!include:.gitignore

# Dependencies
node_modules/
**/node_modules/
node_modules

# Git
.git/
.gitignore

# Build artifacts
dist/

# Environment files
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# Database exports
*.sql

# IDE
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Large/unnecessary files
attached_assets/
docs/
*.md
!README.md

# Test files
coverage/
.nyc_output/
**/*.test.ts
**/*.spec.ts

# Temp files
tmp/
temp/
*.tmp
